# ReadmitRisk environment configuration.
# Copy to `.env` and adjust as needed. All values have sane defaults; no secrets,
# no API keys, no cloud credentials are ever required, this project is local-only.

# ---------------------------------------------------------------------------
# Synthetic data generation
# ---------------------------------------------------------------------------
# Generator backend: "synthea" runs the real Synthea jar (needs Docker/Java);
# "fallback" runs the deterministic Synthea-schema-compatible Python generator.
# "auto" uses Synthea if its jar/output is available, otherwise the fallback.
READMIT_GENERATOR=auto

# Synthetic population size (number of patients to generate).
READMIT_POPULATION=4000

# Master random seed, fixes Synthea AND the fallback generator AND model splits.
READMIT_SEED=42

# ---------------------------------------------------------------------------
# Cohort / modeling
# ---------------------------------------------------------------------------
# Readmission follow-up window in days (event = readmission within this window).
READMIT_FOLLOWUP_DAYS=30

# Fraction of the cohort held out for test evaluation.
READMIT_TEST_SIZE=0.25

# ---------------------------------------------------------------------------
# Paths (inside the container these map to mounted volumes)
# ---------------------------------------------------------------------------
READMIT_DATA_DIR=data

# ---------------------------------------------------------------------------
# Streamlit demo
# ---------------------------------------------------------------------------
READMIT_STREAMLIT_PORT=8501
