# ReadmitRisk — generated artifacts are reproducible; do not commit them.
# Exception: the small cached sample under data/sample/ IS committed (see below).

# Generated data (raw Synthea output + derived cohort + model artifacts)
data/raw/
data/cohort/
data/artifacts/
data/reports/
*.duckdb
*.duckdb.wal

# Keep the committed cached sample used by tests + CI (the cohort parquet + meta only;
# the bulky raw CSVs are regenerated deterministically by `make sample`).
!data/sample/
!data/sample/**
data/sample/raw/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.uv/

# uv
